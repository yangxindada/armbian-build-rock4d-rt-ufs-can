From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Sun, 22 Mar 2026 00:00:00 +0800
Subject: [PATCH] arm64: dts: rockchip: route ROCK 4D header pins to CAN1

The ROCK 4D board DTS enables i2c6 on the same pinmux group needed by the
header CAN1 signals. Disable i2c6 and switch those header pins to CAN1 so
the generated Armbian image boots with a usable CAN bus by default.
---
diff --git a/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts b/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
index ce0100d75b6d..db4f26cad7ab 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
@@ -21,6 +21,10 @@
 / {
 	model = "ROCK 4D";
 	compatible = "radxa,rock-4d", "rockchip,rk3576";
+
+	aliases {
+		can0 = &can1;
+	};
 
 	/delete-node/ chosen;
 
@@ -474,6 +478,21 @@
 	reset-gpios = <&gpio4 RK_PD0 GPIO_ACTIVE_HIGH>;
 };
 
+&can1 {
+	/* Header CAN on PIN_26 (RX) / PIN_28 (TX). */
+	pinctrl-names = "default";
+	pinctrl-0 = <&can1m1_pins>;
+	status = "okay";
+};
+
+&i2c6 {
+	/*
+	 * i2c6m3_xfer shares the same header pinmux as can1m1 on ROCK 4D.
+	 * Disable i2c6 so the header can be dedicated to CAN.
+	 */
+	status = "disabled";
+};
+
 &sdmmc {
 	max-frequency = <200000000>;
 	no-sdio;
-- 
