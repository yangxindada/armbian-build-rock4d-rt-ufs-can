From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Sun, 22 Mar 2026 00:00:00 +0800
Subject: [PATCH] arm64: dts: rockchip: enable ROCK 4D header CAN1

Expose the ROCK 4D header CAN pins through the default device tree so
Armbian images boot with CAN support out of the box.

Map the SoC CAN1 controller to the board header, enable the `can1m1`
pinctrl state, and publish it as Linux `can0` for the common single-bus
use case.
---
diff --git a/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts b/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
index ce0100d75b6d..577b7c4011f6 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-rock-4d.dts
@@ -22,6 +22,10 @@ / {
 	model = "ROCK 4D";
 	compatible = "radxa,rock-4d", "rockchip,rk3576";
 
+	aliases {
+		can0 = &can1;
+	};
+
 	/delete-node/ chosen;
 
 	fan0: pwm-fan {
@@ -474,6 +478,13 @@ &ufs {
 	reset-gpios = <&gpio4 RK_PD0 GPIO_ACTIVE_HIGH>;
 };
 
+&can1 {
+	/* Header CAN on PIN_26 (RX) / PIN_28 (TX). */
+	pinctrl-names = "default";
+	pinctrl-0 = <&can1m1_pins>;
+	status = "okay";
+};
+
 &sdmmc {
 	max-frequency = <200000000>;
 	no-sdio;
-- 
